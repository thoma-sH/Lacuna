# Copy to .env and fill in real values. .env is gitignored.
# .env is bundled as a Flutter asset (see pubspec.yaml) — the app reads it
# at startup in lib/main.dart.

SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>

# Optional. Leave blank to disable Sentry; in that case the app skips
# Sentry initialization entirely and runs the plain LacunaApp.
SENTRY_DSN=
