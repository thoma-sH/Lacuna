# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/
# Local Flutter SDK path (see .vscode/settings.json on your machine)
.vscode/settings.json

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/build/

# Firebase — do not commit; run `flutterfire configure` per machine / CI secret
/android/app/google-services.json
/lib/firebase_options.dart

# Secrets — never commit API keys or environment variables
.env
*.env

# iOS / Xcode — generated, large, or per-machine
ios/Pods/
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
**/*.xcuserstate
**/xcuserdata/

# Android signing — committing a keystore is a permanent leak
android/key.properties
android/app/key.jks
android/app/upload-keystore.jks
*.jks
*.keystore
android/local.properties

# Desktop builds (macOS / Linux / Windows) — not shipping in v1
macos/Pods/
macos/Flutter/GeneratedPluginRegistrant.*
linux/flutter/ephemeral/
windows/flutter/ephemeral/

# Sentry symbol uploads — sometimes auto-generated, large
*.dSYM.zip
*.dSYM/
.sentryclirc

# Test artifacts
/coverage/
/test_reports/
junit.xml

# Misc local
*.iml.bak
*.bak
*.tmp
*.orig

# Claude Code settings and custom skills (local only)
.claude/

# Internal launch tracking — keep local
LAUNCH_CHECKLIST.md
